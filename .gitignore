# ============================================================
# 宠物救助收养系统 - .gitignore 规则
# ============================================================
#
# 使用说明：
# - 本文件配置了需要被 Git 忽略的文件/目录
# - "不忽略"规则（!前缀）表示强制跟踪某些文件
#
# ============================================================

# IDE配置文件
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 编译输出
target/
build/
out/
*.class

# 依赖目录（全部忽略，由 !frontend/node_modules/ 覆盖）
node_modules/
frontend/node_modules/

# 日志文件
*.log

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
*.swp
*~
*.bak

# 上传的文件目录
upload/
uploads/

# 测试输出
test-output/
reports/

# 环境变量文件（可能含敏感信息）
.env
.env.local
.env.*.local

# JAR包（大文件）
*.jar

# 压缩文件
*.zip
*.rar
*.7z

# PDF文档
*.pdf
*.caj

# 图片（大文件，不纳入版本控制）
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.ico

# ============================================================
# 强制跟踪的文件（!前缀）
# ============================================================

# SQL建表脚本（仅结构+虚构测试数据，必须保留）
!sql/

# 保留项目文档
!README.md
!CLAUDE.md
!项目状态保存文档.md
!论文素材保存文档.md
!截图管理文档.md

# 配置文件模板（仅占位符，已移除真实密码）
!backend/src/main/resources/application-example.yml
!backend/src/main/resources/pom.xml
!frontend/package.json
!frontend/vite.config.js
!frontend/index.html

# ============================================================
# 敏感文件（明确不上传）
# ============================================================

# 配置文件（含数据库密码/JWT密钥明文）
# 使用时复制 application-example.yml 并配置环境变量
backend/src/main/resources/application.yml
application.yml

# 截图目录
screenshots/

# 内部交接备忘
HANDOVER.md

# Claude AI 工具配置
.claude/

# 临时调试脚本（以下划线开头，不参与项目构建）
_analyze_*.py
_list_*.py
_insert_*.py
sql/_*.py
sql/_*.sql
sql/*.ps1
sql/*.json

# 前端锁文件（让 clone 者自己 npm install）
frontend/package-lock.json

# 论文相关文件（不纳入版本控制）
thesis-*.md
thesis-outline.md
thesis-template/
毕业设计*.md
